# =============================================================================
# Persona Fashion - Environment Variables
# =============================================================================
# Copy this file to .env and fill in the actual values.
# NEVER commit the .env file to version control.
# =============================================================================

# ---------------------------------------------------------------------------
# Database (Prisma / SQLite)
# ---------------------------------------------------------------------------
DATABASE_URL="file:./dev.db"

# ---------------------------------------------------------------------------
# Authentication (NextAuth.js v4)
# ---------------------------------------------------------------------------
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET="change-me-to-a-random-secret"

# Public URL of the application (used for OAuth callbacks, sitemap, metadata)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# ---------------------------------------------------------------------------
# Google OAuth (optional — enable for Google Sign-In)
# ---------------------------------------------------------------------------
# Obtain from: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# ---------------------------------------------------------------------------
# Cloudinary (Image Uploads)
# ---------------------------------------------------------------------------
# Obtain from: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ---------------------------------------------------------------------------
# Stripe (Payments & Webhooks)
# ---------------------------------------------------------------------------
# Obtain from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_test_placeholder"
# Obtain from: Stripe Dashboard → Webhooks → Signing secret
STRIPE_WEBHOOK_SECRET="whsec_placeholder"

# ---------------------------------------------------------------------------
# AI / LLM Integration (optional — used by style assistant & product descriptions)
# ---------------------------------------------------------------------------
LLM_API_URL=""
LLM_API_KEY=""
LLM_MODEL="moonshot-v1-8k"
