generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Product {
  id          String   @id @default(cuid())
  name        String
  nameAr      String?
  description String
  descriptionAr String?
  price       Float
  salePrice   Float?
  brand       String
  images      String
  category    String
  subcategory String?
  sizes       String
  colors      String
  rating      Float    @default(0)
  reviewCount Int      @default(0)
  inStock     Boolean  @default(true)
  stockCount  Int      @default(100)
  isFeatured  Boolean  @default(false)
  isNew       Boolean  @default(false)
  isBestSeller Boolean @default(false)
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  deals     Deal[]
  cartItems CartItem[]
}

model Category {
  id          String  @id @default(cuid())
  name        String
  nameAr      String?
  slug        String  @unique
  image       String
  description String?
  descriptionAr String?
  order       Int     @default(0)
  isActive    Boolean @default(true)
}

model Deal {
  id          String   @id @default(cuid())
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  title       String
  titleAr     String?
  discountPercent Int
  startsAt    DateTime
  endsAt      DateTime
  isActive    Boolean  @default(true)
  maxQuantity Int?
  soldCount   Int      @default(0)
  createdAt   DateTime @default(now())
}

model CartItem {
  id          String   @id @default(cuid())
  userId      String?
  sessionId   String?
  productId   String
  product     Product  @relation(fields: [productId], references: [id])
  quantity    Int      @default(1)
  size        String?
  color       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
